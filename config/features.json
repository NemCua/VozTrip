{
  "app": {
    "name": "VozTrip",
    "version": "1.0.0",
    "maintenance": {
      "enabled": false,
      "message": "VozTrip đang bảo trì. Vui lòng quay lại sau."
    }
  },

  "auth": {
    "login":    { "enabled": true },
    "register": { "enabled": true },
    "jwt": { "accessTokenTTL": "7d" }
  },

  "features": {
    "guest": {
      "languagePicker": { "enabled": true },
      "explorePois": {
        "enabled": true,
        "localizedName": { "enabled": true },
        "thumbnail":     { "enabled": true }
      },
      "nearbyPois": { "enabled": true },
      "map":        { "enabled": true },
      "poiDetail": {
        "enabled": true,
        "media":        { "enabled": true },
        "localization": { "enabled": true },
        "audio":        { "enabled": true }
      },
      "qna": { "enabled": true },
      "gpsVisitLog": {
        "enabled": true,
        "qrScan":   { "enabled": true },
        "session":  { "enabled": true },
        "visitLog": { "enabled": true }
      },
      "usageLog": { "enabled": true }
    },

    "seller": {
      "profile": { "enabled": true },
      "vipUpgrade": {
        "enabled": true,
        "mockPayment": { "enabled": true },
        "sePayQr":     { "enabled": true }
      },
      "poiBoost": {
        "enabled":    true,
        "boostDays":  30,
        "boostPrice": 3000
      },
      "dashboard": {
        "enabled": true,
        "totalVisits":     { "enabled": true },
        "top5Pois":        { "enabled": true },
        "visitChart7Days": { "enabled": true }
      },
      "poiManagement": {
        "enabled": true,
        "create": { "enabled": true },
        "update": { "enabled": true },
        "delete": { "enabled": true },
        "planLimit": {
          "enabled": true,
          "freePlanMaxPois": 1
        }
      },
      "localization": {
        "enabled": true,
        "upsert": { "enabled": true },
        "delete": { "enabled": true }
      },
      "audioUpload": {
        "enabled": true,
        "uploadToCloudinary": { "enabled": true },
        "deleteOldOnReplace": { "enabled": true }
      },
      "autoTranslate": {
        "enabled": true,
        "provider": "LibreTranslate",
        "skipExistingManual": { "enabled": true }
      },
      "mediaManagement": {
        "enabled": true,
        "upload": {
          "enabled": true,
          "image": { "enabled": true },
          "video": { "enabled": true }
        },
        "reorder": { "enabled": true },
        "delete":  { "enabled": true }
      },
      "qnaManagement": {
        "enabled": true,
        "createQuestion": { "enabled": true },
        "upsertAnswer":   { "enabled": true },
        "deleteQuestion": { "enabled": true }
      }
    },

    "admin": {
      "dashboard": {
        "enabled": true,
        "systemStats":     { "enabled": true },
        "top5Pois":        { "enabled": true },
        "visitChart7Days": { "enabled": true }
      },
      "sellerManagement": {
        "enabled": true,
        "list":    { "enabled": true },
        "approve": { "enabled": true },
        "create":  { "enabled": true }
      },
      "userManagement": {
        "enabled": true,
        "list":       { "enabled": true },
        "toggleLock": { "enabled": true },
        "delete":     { "enabled": true }
      },
      "mediaModeration": {
        "enabled": true,
        "viewAll": { "enabled": true },
        "deleteViolation": {
          "enabled": true,
          "cleanCloudinary": { "enabled": true }
        }
      },
      "poiModeration": {
        "enabled": true,
        "list":         { "enabled": true },
        "detail":       { "enabled": true },
        "toggleActive": { "enabled": true },
        "delete": {
          "enabled": true,
          "cleanCloudinary": { "enabled": true }
        }
      },
      "zoneManagement": {
        "enabled": true,
        "create": { "enabled": true },
        "update": { "enabled": true },
        "delete": { "enabled": true }
      },
      "languageManagement": {
        "enabled": true,
        "create":       { "enabled": true },
        "update":       { "enabled": true },
        "toggleActive": { "enabled": true }
      },
      "deviceTracking": {
        "enabled": true,
        "delete":  { "enabled": true }
      }
    }
  },

  "pages": {
    "privacy":   { "enabled": true },
    "emergency": { "enabled": false, "message": "Hệ thống đang xử lý sự cố khẩn cấp." },
    "feedback":  { "enabled": true }
  }
}
